// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   // For credentials auth
  role          UserRole  @default(USER)
  clientNumber  String?   @unique // Only for regular users
  
  // Profile fields
  avatar        String?   // URL to cloud storage
  bio           String?
  phone         String?
  website       String?
  company       String?
  jobTitle      String?
  location      String?
  
  // Social links stored as JSON
  socialLinks   String?   // JSON: { linkedin, twitter, facebook, instagram }
  
  // Preferences stored as JSON
  preferences   String?   // JSON: { emailNotifications, pushNotifications, ... }
  
  // Status
  isSuspended   Boolean   @default(false)
  suspensionReason String?
  emailVerified DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  loginCount    Int       @default(0)
  
  // Relations
  listings      Listing[]
  offers        Offer[]
  messages      Message[]
  notifications Notification[]
  watchlist     WatchlistItem[]
  supportTickets SupportTicket[]
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]
  promotions    Promotion[]
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
  OWNER
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ==================== LISTINGS ====================

model Listing {
  id              String        @id @default(cuid())
  title           String
  description     String
  category        String
  industry        String?
  location        String
  region          String
  
  // Financials
  askingPrice     Float
  revenue         Float
  ebitda          Float?
  growthRate      Float?
  employees       Int?
  yearEstablished Int?
  
  // Status
  status          ListingStatus @default(PENDING)
  isFeatured      Boolean       @default(false)
  isVerified      Boolean       @default(false)
  verificationDate DateTime?
  
  // Media
  images          String?       // JSON array of image URLs
  
  // Metadata
  viewCount       Int           @default(0)
  inquiryCount    Int           @default(0)
  
  // NDA required to view details
  ndaRequired     Boolean       @default(true)
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?
  expiresAt       DateTime?
  
  // Relations
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  offers          Offer[]
  watchlistItems  WatchlistItem[]
  promotions      Promotion[]
  
  @@index([category])
  @@index([region])
  @@index([status])
}

enum ListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  SOLD
  EXPIRED
}

// ==================== OFFERS & TRANSACTIONS ====================

model Offer {
  id            String      @id @default(cuid())
  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  
  amount        Float
  message       String?
  
  status        OfferStatus @default(PENDING)
  
  // Due diligence
  ndaSigned     Boolean     @default(false)
  ndaSignedAt   DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  respondedAt   DateTime?
  
  @@index([status])
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  COMPLETED
}

// ==================== MESSAGING ====================

model Message {
  id          String     @id @default(cuid())
  senderId    String
  sender      User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  recipientId String?
  listingId   String?    // Context for the message
  
  subject     String
  content     String
  
  isRead      Boolean    @default(false)
  readAt      DateTime?
  
  // For threaded conversations
  parentId    String?
  parent      Message?   @relation("MessageThread", fields: [parentId], references: [id])
  replies     Message[]  @relation("MessageThread")
  
  createdAt   DateTime   @default(now())
  
  @@index([senderId])
  @@index([recipientId])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        NotificationType
  title       String
  message     String
  link        String?
  
  isRead      Boolean          @default(false)
  readAt      DateTime?
  
  createdAt   DateTime         @default(now())
  
  @@index([userId, isRead])
}

enum NotificationType {
  LISTING_APPROVED
  LISTING_REJECTED
  NEW_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  NEW_MESSAGE
  SYSTEM
  MARKETING
}

// ==================== WATCHLIST ====================

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, listingId])
}

// ==================== SUPPORT ====================

model SupportTicket {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  subject     String
  description String
  category    String?
  priority    TicketPriority @default(NORMAL)
  status      TicketStatus @default(OPEN)
  
  assignedTo  String?      // Admin user ID
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  closedAt    DateTime?
  
  replies     TicketReply[]
  
  @@index([status])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  authorId  String
  isStaff   Boolean  @default(false)
  
  content   String
  createdAt DateTime @default(now())
  
  @@index([ticketId])
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

// ==================== AUDIT LOGGING ====================

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  
  action    String   // e.g., "user.login", "listing.create"
  targetType String? // "user", "listing", "offer", etc.
  targetId   String?
  
  details   String?  // JSON
  ipAddress String?
  userAgent String?
  severity  AuditSeverity @default(INFO)
  
  // For tracking changes
  beforeData String? // JSON
  afterData  String? // JSON
  
  createdAt DateTime @default(now())
  
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

// ==================== RATE LIMITING (Server-Side) ====================

model RateLimitRecord {
  id          String   @id @default(cuid())
  type        String   // "api", "auth", "search", etc.
  identifier  String   // IP or user ID
  
  requestCount Int     @default(1)
  windowStart DateTime @default(now())
  windowEnd   DateTime
  
  isBlocked   Boolean  @default(false)
  blockedUntil DateTime?
  
  createdAt   DateTime @default(now())
  
  @@unique([type, identifier])
  @@index([windowEnd])
}

// ==================== ADVERTISING / PROMOTIONS ====================

model Promotion {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  // Purchased by
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        PromotionType
  startDate   DateTime
  endDate     DateTime
  
  price       Float
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  
  status      PromotionStatus @default(PENDING)
  
  createdAt   DateTime @default(now())
  
  @@index([status])
}

enum PromotionType {
  FEATURED
  HIGHLIGHTED
  CATEGORY_SPOTLIGHT
  NEWSLETTER
}

enum PromotionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

// ==================== SYSTEM SETTINGS ====================

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON
  updatedAt DateTime @updatedAt
}
